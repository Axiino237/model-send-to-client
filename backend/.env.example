PORT=5000

# ============================================================
# Supabase PostgreSQL (Pooled connection - for runtime queries)
# Project ref: hvkymjoccakzptaaydai
# ============================================================
DATABASE_URL="postgresql://postgres.hvkymjoccakzptaaydai:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"

# Direct connection - used for Prisma migrate (no pgBouncer)
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.hvkymjoccakzptaaydai.supabase.co:5432/postgres"

# JWT Secret - use a strong random string
JWT_SECRET="replace_with_strong_random_secret"

# Frontend URL for CORS (set to your Render frontend URL after deploy)
FRONTEND_URL="http://localhost:5173"

# ============================================================
# Uploadthing Storage (Priority 1 - Free 2GB, NO credit card!)
# Setup: https://uploadthing.com -> Sign up -> Create App -> API Keys
# ============================================================
UPLOADTHING_TOKEN=your_uploadthing_token_here

# ============================================================
# Cloudflare R2 Storage (Priority 2 - needs credit card to activate)
# ============================================================
# CLOUDFLARE_R2_ACCOUNT_ID=your_account_id_here
# CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# CLOUDFLARE_R2_BUCKET_NAME=model-files
# CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.your-subdomain.r2.dev

# ============================================================
# AWS S3 Settings (Legacy - not used if Uploadthing is configured)
# ============================================================
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET_NAME=models-link-share-uploads
